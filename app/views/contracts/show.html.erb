
<p class="text-green-600"><%= notice %></p>

<div class="bg-white shadow rounded p-6 mb-4">
  <h2 class="text-xl font-semibold mb-2"><%= @contract.title %></h2>
  <p class="mb-2"><strong>Created At:</strong> <%= @contract.created_at.strftime('%Y-%m-%d') %></p>
  <p class="mb-2"><strong>Content:</strong> <%= @contract.content %></p>
  <% if @contract.extracted_clauses.present? %>
    <div class="mt-4">
      <strong>Extracted Clauses:</strong>
      <pre class="bg-gray-100 p-2 rounded text-xs"><%= JSON.pretty_generate(@contract.extracted_clauses) %></pre>
    </div>
  <% end %>
  <% if @contract.risk_flags.present? %>
    <div class="mt-4">
      <strong>Risk Flags:</strong>
      <pre class="bg-red-100 p-2 rounded text-xs"><%= JSON.pretty_generate(@contract.risk_flags) %></pre>
    </div>
  <% end %>
</div>

<div class="space-x-2">
  <%= link_to "Edit", edit_contract_path(@contract), class: "btn btn-warning" %>
  <%= link_to "Back", contracts_path, class: "btn btn-secondary" %>
  <%= button_to "Destroy", @contract, method: :delete, class: "btn btn-danger" %>
</div>

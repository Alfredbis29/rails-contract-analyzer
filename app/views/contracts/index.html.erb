<% if notice.present? %>
  <div class="flex items-center gap-2 bg-green-50 border-l-4 border-green-600 text-green-800 text-sm font-medium px-4 py-3 rounded-md mb-8">
    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    <%= notice %>
  </div>
<% end %>

<div class="min-h-screen bg-stone-50 px-10 py-12 font-sans">

  <%# Header %>
  <div class="flex items-end justify-between pb-6 mb-8 border-b border-stone-200">
    <div>
      <p class="text-xs font-semibold tracking-widest uppercase text-amber-600 mb-1">Document Management</p>
      <h1 class="text-4xl font-bold text-stone-900">All Contracts</h1>
    </div>
    <%= link_to new_contract_path,
          class: "inline-flex items-center gap-2 bg-stone-900 hover:bg-amber-600 text-white text-sm font-semibold px-5 py-3 rounded-lg transition-colors duration-150" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New Contract
    <% end %>
  </div>

  <%# Table card %>
  <div class="bg-white border border-stone-200 rounded-xl overflow-hidden shadow-sm">
    <table class="w-full border-collapse">
      <thead>
        <tr class="bg-stone-100 border-b border-stone-200">
          <th class="text-left text-xs font-semibold tracking-widest uppercase text-stone-400 px-5 py-3">Title</th>
          <th class="text-left text-xs font-semibold tracking-widest uppercase text-stone-400 px-5 py-3">Created</th>
          <th class="text-left text-xs font-semibold tracking-widest uppercase text-stone-400 px-5 py-3">Status</th>
          <th class="text-right text-xs font-semibold tracking-widest uppercase text-stone-400 px-5 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if @contracts.any? %>
          <% @contracts.each do |contract| %>
            <tr class="border-b border-stone-100 last:border-0 hover:bg-stone-50 transition-colors duration-100">
              <td class="px-5 py-4 text-sm font-semibold text-stone-900"><%= contract.title %></td>
              <td class="px-5 py-4 text-xs font-mono text-stone-400"><%= contract.created_at.strftime('%b %d, %Y') %></td>
              <td class="px-5 py-4"><%= status_badge(contract.status) %></td>
              <td class="px-5 py-4 text-right">
                <%= link_to contract,
                      class: "inline-flex items-center gap-1.5 text-xs font-semibold text-amber-600 border border-amber-500 hover:bg-amber-600 hover:text-white px-3 py-1.5 rounded transition-colors duration-150" do %>
                  View
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="px-5 py-16 text-center text-sm text-stone-400">
              No contracts yet — create your first one.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <div class="flex justify-center mt-6">
    <%= paginate @contracts, theme: 'tailwind' %>
  </div>

</div>

<p class="text-green-600"><%= notice %></p>

<h1 class="text-2xl font-bold mb-4">Contracts</h1>

<table class="min-w-full border border-gray-300 mb-6">
  <thead>
    <tr class="bg-gray-100">
      <th class="px-4 py-2">Title</th>
      <th class="px-4 py-2">Created At</th>
      <th class="px-4 py-2">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @contracts.each do |contract| %>
      <tr class="border-t">
        <td class="px-4 py-2"><%= contract.title %></td>
        <td class="px-4 py-2"><%= contract.created_at.strftime('%Y-%m-%d') %></td>
        <td class="px-4 py-2">
          <%= link_to "Show", contract, class: "btn btn-sm btn-primary" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @contracts %>

<%= link_to "New contract", new_contract_path, class: "btn btn-success" %>
